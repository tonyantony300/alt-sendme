# Copy to iroh-relay.conf and edit before starting.
# cp iroh-relay.conf.example iroh-relay.conf

enable_quic_addr_discovery = true

[tls]
cert_mode = "LetsEncrypt"
hostname = "euc1-1.relay.example.com"
# Multiple hostnames for one relay (optional):
# hostname = ["use1-1.relay.example.com", "euc1-1.relay.example.com"]
contact = "you@example.com"
cert_dir = "/data/certs"

# Optional: restrict relay to clients that present a shared token.
# Set the same token in AltSendme → Settings → Network → Auth token.
# access.shared_token = ["CHANGE_ME_TO_A_LONG_RANDOM_SECRET"]
